# Email Configuration (Resend) - for Vercel deployment
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Email recipient - where form submissions will be sent
SEND_TO=accounts@pdcon.com.au

# Email sender - must be a verified domain in Resend
# Format: "Name <email@yourdomain.com>"
SEND_FROM=Desk <desk@pdcon.com.au>

# Add these environment variables in your Vercel project settings:
# 1. Go to your Vercel project dashboard
# 2. Settings > Environment Variables
# 3. Add RESEND_API_KEY, SEND_TO, and SEND_FROM
